# --- Gradle ---
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
# Dependency lock files (regenerated on dependency changes)
gradle.lockfile
**/gradle.lockfile
settings-gradle.lockfile

# --- IntelliJ IDEA ---
*.iml
.idea/

# --- Eclipse ---
.factorypath
.classpath
.project
.settings/
bin/

# --- Environment files (may contain API keys and secrets) ---
.env
.env.local
.env.*
!.env.example

# --- Build outputs ---
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# --- Logs ---
*.log

# --- OS files ---
.DS_Store
Thumbs.db

# --- OpenCode runtime data ---
.omo/

# --- JVM crash logs ---
hs_err_pid*
replay_pid*

# --- Untracked scratch dirs (extracted JARs, debug scripts, smoke test outputs) ---
# These are session-local artifacts. Never commit; never name a real dir with this prefix.
/tmp-*/
tmp-*/

# --- Local RocketMQ RocksDB store (bind-mounted into the broker container) ---
# Survives container restarts; ephemeral. Persists messages, topic metadata,
# consumer offsets. Must never enter source control.
docker/rocketmq/data/